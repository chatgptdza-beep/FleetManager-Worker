<Window x:Class="FleetManager.Desktop.VpsEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Add VPS"
        Width="520"
        SizeToContent="Height"
        MaxHeight="800"
        WindowStartupLocation="CenterOwner"
        Background="#0E1A24">
    <Grid>
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <Border Margin="20"
                    Padding="24"
                    Background="#162532"
                    BorderBrush="#2C3A43"
                    BorderThickness="1"
                    CornerRadius="24">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <StackPanel>
                        <TextBlock Foreground="#F8F5F1"
                                   FontSize="26"
                                   FontWeight="Bold"
                                   Text="Add VPS" />
                        <TextBlock Margin="0,8,0,0"
                                   Foreground="#B9C4CD"
                                   TextWrapping="Wrap"
                                   Text="Register a new node so the dashboard can assign accounts and dispatch worker commands." />
                    </StackPanel>

                    <Grid Grid.Row="1" Margin="0,24,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0" Grid.ColumnSpan="2">
                            <TextBlock Margin="0,0,0,8" Foreground="#B9C4CD" FontSize="13" Text="Name" />
                            <TextBox x:Name="NameTextBox" Height="42" Text="VPS-NEW-01" />
                        </StackPanel>

                        <StackPanel Grid.Row="1" Grid.ColumnSpan="2" Margin="0,16,0,0">
                            <TextBlock Margin="0,0,0,8" Foreground="#B9C4CD" FontSize="13" Text="IP Address" />
                            <TextBox x:Name="IpAddressTextBox" Height="42" Text="10.0.0.90" />
                        </StackPanel>

                        <StackPanel Grid.Row="2" Grid.Column="0" Margin="0,16,8,0">
                            <TextBlock Margin="0,0,0,8" Foreground="#B9C4CD" FontSize="13" Text="SSH Port" />
                            <TextBox x:Name="SshPortTextBox" Height="42" Text="22" />
                        </StackPanel>

                        <StackPanel Grid.Row="2" Grid.Column="1" Margin="8,16,0,0">
                            <TextBlock Margin="0,0,0,8" Foreground="#B9C4CD" FontSize="13" Text="Control Port" />
                            <TextBox x:Name="ControlPortTextBox" Height="42" Text="9001" />
                        </StackPanel>

                        <StackPanel Grid.Row="3" Grid.ColumnSpan="2" Margin="0,16,0,0">
                            <TextBlock Margin="0,0,0,8" Foreground="#B9C4CD" FontSize="13" Text="SSH Username" />
                            <TextBox x:Name="SshUsernameTextBox" Height="42" Text="fleetmgr" />
                        </StackPanel>



                        <StackPanel Grid.Row="4" Grid.ColumnSpan="2" Margin="0,16,0,0">
                            <TextBlock Margin="0,0,0,8" Foreground="#B9C4CD" FontSize="13" Text="SSH Password" />
                            <TextBox x:Name="SshPasswordTextBox" Height="42" />
                        </StackPanel>

                        <StackPanel Grid.Row="5" Grid.ColumnSpan="2" Margin="0,16,0,0">
                            <TextBlock Margin="0,0,0,8" Foreground="#B9C4CD" FontSize="13" Text="SSH Private Key (Import file)" />
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBox x:Name="SshPrivateKeyTextBox" Height="42" Padding="12,0" VerticalContentAlignment="Center" IsReadOnly="True" />
                                <Button Grid.Column="1" Margin="8,0,0,0" Style="{StaticResource GhostButtonStyle}" Height="42" Padding="16,0" Click="ImportKey_Click" Content="Import Key" />
                            </Grid>
                        </StackPanel>

                    </Grid>

                    <StackPanel Grid.Row="2" Margin="0,28,0,0" Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Style="{StaticResource GhostButtonStyle}" Width="120" Height="44" Margin="0,0,12,0" Click="Cancel_Click" Content="Cancel" />
                        <Button Style="{StaticResource PrimaryButtonStyle}" Width="120" Height="44" Click="Save_Click" Content="Add VPS" />
                    </StackPanel>
                </Grid>
            </Border>
        </ScrollViewer>
    </Grid>
</Window>
