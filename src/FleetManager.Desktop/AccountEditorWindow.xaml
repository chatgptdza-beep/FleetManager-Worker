<Window x:Class="FleetManager.Desktop.AccountEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Account Editor"
        Width="460"
        SizeToContent="Height"
        MaxHeight="600"
        WindowStartupLocation="CenterOwner"
        Background="#0E1A24">
    <Grid>
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <Border Margin="20" Padding="24" Background="#162532" BorderBrush="#2C3A43" BorderThickness="1" CornerRadius="22">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    
                    <TextBlock Foreground="#F8F5F1" FontSize="26" FontWeight="Bold" Text="{Binding EditorTitle}" />
                    <TextBlock Grid.Row="1" Margin="0,10,0,0" Foreground="#B9C4CD" Text="{Binding NodeLabel}" TextWrapping="Wrap" />
                    
                    <StackPanel Grid.Row="2" Margin="0,20,0,0">
                        <TextBlock Margin="0,0,0,8" Foreground="#B9C4CD" FontSize="13" Text="Email Address" />
                        <TextBox Height="42" Text="{Binding Email}" />
                    </StackPanel>

                    <StackPanel Grid.Row="3" Margin="0,16,0,0">
                        <TextBlock Margin="0,0,0,8" Foreground="#B9C4CD" FontSize="13" Text="Username" />
                        <TextBox Height="42" Text="{Binding Username}" />
                    </StackPanel>

                    <StackPanel Grid.Row="4" Margin="0,16,0,0">
                        <TextBlock Margin="0,0,0,8" Foreground="#B9C4CD" FontSize="13" Text="Current Status" />
                        <ComboBox Height="42" ItemsSource="{Binding StatusOptions}" SelectedItem="{Binding Status}" />
                    </StackPanel>
                    
                    <StackPanel Grid.Row="6" Margin="0,24,0,0" Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Style="{StaticResource GhostButtonStyle}" Width="110" Margin="0,0,12,0" Click="Cancel_Click" Content="Cancel" />
                        <Button Style="{StaticResource PrimaryButtonStyle}" Width="110" Click="Save_Click" Content="Save" />
                    </StackPanel>
                </Grid>
            </Border>
        </ScrollViewer>
    </Grid>
</Window>
