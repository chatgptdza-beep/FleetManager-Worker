FROM ubuntu:22.04

ENV DEBIAN_FRONTEND=noninteractive
ENV NODE_ENV=production

# Install dependencies, Xvfb, x11vnc, noVNC, fluxbox, Node.js and Playwright dependencies
RUN apt-get update && apt-get install -y \
    curl \
    wget \
    gnupg \
    xvfb \
    x11vnc \
    fluxbox \
    python3-websockify \
    novnc \
    libnss3 \
    libatk-bridge2.0-0 \
    libxcomposite1 \
    libxdamage1 \
    libxrandr2 \
    libgbm1 \
    libxkbcommon0 \
    libasound2 \
    && curl -fsSL https://deb.nodesource.com/setup_20.x | bash - \
    && apt-get install -y nodejs \
    && apt-get clean \
    && rm -rf /var/lib/apt/lists/*

# Set up app directory
WORKDIR /app

# Install Playwright and stealth plugin
RUN npm init -y && \
    npm install playwright puppeteer-extra puppeteer-extra-plugin-stealth

# Ensure browsers are installed
RUN npx playwright install chromium
RUN npx playwright install-deps

# Create entrypoint script
RUN echo '#!/bin/bash\n\
export DISPLAY=:99\n\
rm -f /tmp/.X99-lock\n\
\n\
# Start Xvfb (Virtual Framebuffer)\n\
Xvfb :99 -screen 0 1280x800x24 -nolisten tcp &\n\
\n\
# Start window manager\n\
fluxbox &\n\
\n\
# Start VNC server (bound to localhost for security, noVNC will expose it)\n\
x11vnc -display :99 -nopw -listen localhost -xkb -ncache 10 -ncache_cr -forever &\n\
\n\
# Start noVNC (exposes port 6080 inside container)\n\
websockify --web=/usr/share/novnc/ 6080 localhost:5900 &\n\
\n\
# Execute the Node.js script passed to the container\n\
exec node "$@"\n\
' > /app/entrypoint.sh && chmod +x /app/entrypoint.sh

EXPOSE 6080

ENTRYPOINT ["/app/entrypoint.sh"]
